# DVC ignore patterns — files/dirs excluded from DVC tracking

# Git
.git/

# Python
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/

# Virtual environments
venv/
.venv/
/venv/

# Node
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Old experiment outputs (tracked separately)
Reading/

# DVC internals
.dvc/tmp/
.dvc/cache/
